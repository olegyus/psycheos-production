# PsycheOS Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PgBouncer pooler URL (port 6543) — used by the app at runtime
DATABASE_URL_POOLER=postgresql+psycopg://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Direct connection URL (port 5432) — used ONLY by Alembic migrations
DATABASE_URL_DIRECT=postgresql+psycopg://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Connection pool limits per process (keep low — multiple replicas share Supabase)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

# ── Monitoring ────────────────────────────────────────────────────────────────
# Optional — leave empty to disable Sentry
SENTRY_DSN=

# ── Claude AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Telegram Bot Tokens ───────────────────────────────────────────────────────
TG_TOKEN_PRO=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TG_TOKEN_SCREEN=1234567891:BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB
TG_TOKEN_INTERPRETATOR=1234567892:CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC
TG_TOKEN_CONCEPTUALIZATOR=1234567893:DDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDD
TG_TOKEN_SIMULATOR=1234567894:EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

# ── Telegram Webhook Secrets ──────────────────────────────────────────────────
# Random strings — set once, must match what Telegram expects
TG_WEBHOOK_SECRET_PRO=generate-a-random-string-here
TG_WEBHOOK_SECRET_SCREEN=generate-a-random-string-here
TG_WEBHOOK_SECRET_INTERPRETATOR=generate-a-random-string-here
TG_WEBHOOK_SECRET_CONCEPTUALIZATOR=generate-a-random-string-here
TG_WEBHOOK_SECRET_SIMULATOR=generate-a-random-string-here

# ── Telegram Bot Usernames (without @) ───────────────────────────────────────
# Used to generate deep links: t.me/{username}?start={jti}
TG_USERNAME_SCREEN=psycheos_screen_bot
TG_USERNAME_INTERPRETATOR=psycheos_interp_bot
TG_USERNAME_CONCEPTUALIZATOR=psycheos_concept_bot
TG_USERNAME_SIMULATOR=psycheos_sim_bot

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs with admin access
ADMIN_IDS=123456789,987654321

# Single chat/user ID for admin alerts (optional)
ADMIN_CHAT_ID=

# ── App ───────────────────────────────────────────────────────────────────────
WEBHOOK_BASE_URL=https://your-app.railway.app
DEBUG=false
